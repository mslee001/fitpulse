# Django
DJANGO_SECRET_KEY=your-secret-key-here        # generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_DEBUG=True

# Peloton — grab these from browser DevTools after logging in to one.peloton.com
# Application tab → Cookies → peloton_session_id / userid
PELOTON_SESSION_ID=your-session-id-from-browser-cookies
PELOTON_USER_ID=your-peloton-user-id

# Anthropic (Claude API) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Garmin Connect — used by the garminconnect library for first-time auth
# Run: venv/bin/python3 manage.py garmin_login
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password

# Withings OAuth 2.0 — create an app at https://developer.withings.com/
# Set redirect URI to: http://localhost:8000/auth/withings/callback/
# Run first-time auth: venv/bin/python3 manage.py withings_login
WITHINGS_CLIENT_ID=your-withings-client-id
WITHINGS_CLIENT_SECRET=your-withings-client-secret
WITHINGS_REDIRECT_URI=http://localhost:8000/auth/withings/callback/
